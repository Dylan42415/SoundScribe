# SoundScribe Free-Tier Environment Variables

# Supabase Configuration
# Required for Database, Auth, and Storage plugins
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-settings

# Vite env variables for frontend to consume
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-settings

# Database Connection (Direct database access from Supabase)
DATABASE_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Groq AI Integrations (Whisper transcription & Llama 3)
GROQ_API_KEY=gsk_your_groq_api_key_here

# (Optional) YouTube cookies if you want to import from YouTube without blocks
# YOUTUBE_COOKIES="..."
